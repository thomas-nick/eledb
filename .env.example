# Hostinger MySQL (mahoot.xyz)
# Copy to .env.local and fill in real values from hPanel → Databases

MYSQL_HOST=srvXXXX.hstgr.io
MYSQL_PORT=3306
MYSQL_DATABASE=u196551923_eleph
MYSQL_USER=u196551923_asianele
MYSQL_PASSWORD=your-password-here

# Set to "disabled" to force local seed JSON only
# MYSQL_HOST=disabled

# Auth (mahoot.xyz production)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://mahoot.xyz
AUTH_TRUST_HOST=true
# Dev: AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect: https://mahoot.xyz/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails auto-promoted to admin on signup/sign-in
ADMIN_EMAILS=you@example.com

# Persistent upload directory on Hostinger Node (outside deploy folder)
# UPLOAD_DIR=/home/u123456/domains/mahoot.xyz/private/uploads

# SYNC_MAX_RECORDS=500
# SYNC_MAX_ID=18500
# SYNC_BATCH_SIZE=50
# SYNC_THAILAND_MAX_RECORDS=0
# SYNC_THAILAND_MAX_LOCATIONS=0
# SYNC_DELAY_MS=1200
# SYNC_MAX_RUNTIME_MS=19800000
