# Paste this into hPanel → Websites → mahoot.xyz → Deployments → Settings & Redeploy
# → Environment variables → Import .env
# Copy from your local .env.production (real secrets) — do not commit that file.

MYSQL_HOST=srv1529.hstgr.io
MYSQL_PORT=3306
MYSQL_DATABASE=u196551923_eleph
MYSQL_USER=u196551923_asianele
MYSQL_PASSWORD=your-password-from-hpanel-databases

AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=same-as-auth-secret
AUTH_URL=https://mahoot.xyz
NEXTAUTH_URL=https://mahoot.xyz
AUTH_TRUST_HOST=true

ADMIN_EMAILS=you@example.com

UPLOAD_DIR=/home/u196551923/domains/mahoot.xyz/private/uploads

# Typesense search (optional — see docs/TYPESENSE.md)
# TYPESENSE_HOST=xxx.a1.typesense.net
# TYPESENSE_PORT=443
# TYPESENSE_PROTOCOL=https
# TYPESENSE_API_KEY=your-admin-api-key
# TYPESENSE_SEARCH_ONLY_KEY=your-search-only-key

# Client-side instant search (search-only key — safe to expose in browser)
# NEXT_PUBLIC_TYPESENSE_HOST=xxx.a1.typesense.net
# NEXT_PUBLIC_TYPESENSE_PORT=443
# NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
# NEXT_PUBLIC_TYPESENSE_SEARCH_KEY=your-search-only-key

# Optional — Google sign-in
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional — analytics (must be set before build if used)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mahoot.xyz
